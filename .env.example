# Discord Bot Token（必填）
BOT_TOKEN=your_BOT_TOKEN_here

# Node 環境
NODE_ENV=production

# 用於加密 RCON 密碼等敏感資料的金鑰（Production 必填）
# 產生方式：openssl rand -hex 32
ENCRYPTION_KEY=

# Web 管理介面對外監聽埠（host 端），預設 3000
WEB_PORT=902

# Web 管理介面監聽位址，預設 0.0.0.0
# WEB_HOST=0.0.0.0

# Bot 持有者的 Discord user id（Production 必填；僅此 id 可透過私訊 bot 取得 admin 登入連結）
# 未設定時 /api/* 不啟用驗證（僅本機 dev 暫用）
BOT_OWNER_ID=

# Plugin 註冊用的共享 secret（Production 必填）。Plugin 在第一次連到 bot 時用 X-Plugin-Setup-Secret
# header 提供此值,bot 驗過後核發 plugin token。未設定時 /api/plugins/register
# 直接 503,Plugin 機制完全停用。
# 產生方式: openssl rand -hex 32
KARYL_PLUGIN_SECRET=

# 前端對外網址，bot 私訊回傳的登入連結會以此為 base
# 走 HTTPS 時請填 https://${DOMAIN}:${WEB_PORT}
WEB_BASE_URL=https://bot.example.com:902

# --- HTTPS 憑證 ---
# Host 上放置憑證的絕對目錄，內含 fullchain.pem 與 privkey.pem。
# docker-compose 會以 read-only mount 到 container 的 /certs，
# 對應 SSL_CERT_PATH=/certs/fullchain.pem、SSL_KEY_PATH=/certs/privkey.pem（已寫在 compose）。
#
# 建議在 Mac host 用 acme.sh 搭配 Cloudflare DNS-01 簽發（Cloudflare 請保持灰雲）：
#
#   # 安裝（會自動建立 crontab 做續期）
#   curl https://get.acme.sh | sh -s email=you@example.com
#
#   # 設定 Cloudflare API token（Zone/DNS/Edit，限定 zone）
#   export CF_Token="your_cloudflare_api_token"
#
#   # 簽發
#   ~/.acme.sh/acme.sh --issue --dns dns_cf -d bot.example.com
#
#   # 安裝到固定路徑 + 續期後自動重啟 bot container
#   mkdir -p $HOME/karyl-chan/certs
#   ~/.acme.sh/acme.sh --install-cert -d bot.example.com \
#     --fullchain-file $HOME/karyl-chan/certs/fullchain.pem \
#     --key-file       $HOME/karyl-chan/certs/privkey.pem \
#     --reloadcmd      "docker restart karyl-chan-bot-1"
#
# 註：bot 讀取憑證只在啟動時（readFileSync），因此 acme.sh 續期後
# 需要重啟 container 才會吃到新憑證，reloadcmd 就是做這件事。
CERTS_DIR=/Users/yourname/karyl-chan/certs

# SQLite 資料庫路徑，預設為 <project-root>/data/database.sqlite
# SQLITE_DB_PATH=/data/database.sqlite

# JWT 登入連結 token 存活時間（毫秒）。Bot 私訊回傳的登入連結在此時間後過期。
# 預設 300000 (5 分鐘)
# JWT_LOGIN_LINK_TTL_MS=300000

# JWT Secret — 用於簽發 / 驗證 bot 登入連結。
# 建議在 production 設定，未設定時每次重啟都用隨機 secret（現有連結失效）。
# 產生方式：openssl rand -hex 64
# JWT_SECRET=

# Access token 存活時間（毫秒）。管理介面每次 API call 需持有有效 access token。
# 預設 900000 (15 分鐘)
# JWT_ACCESS_TTL_MS=900000

# Refresh token 存活時間（毫秒）。用於換取新 access token。
# 預設 604800000 (7 天)
# JWT_REFRESH_TTL_MS=604800000

# SSE ticket 存活時間（毫秒）。EventSource 用的一次性票券，開啟連線後即失效。
# 預設 60000 (60 秒)
# JWT_SSE_TICKET_TTL_MS=60000

# Token 過期清理週期（毫秒）。Auth store 背景清理過期 token 的頻率。
# 預設 60000 (60 秒)
# JWT_CLEANUP_INTERVAL_MS=60000

# Plugin token 存活時間（毫秒）。Plugin 每次 heartbeat 都會延長 expiry。
# 預設 3600000 (1 小時)
# PLUGIN_TOKEN_TTL_MS=3600000

# Plugin heartbeat 超時（毫秒）。Plugin 多久沒 heartbeat 就被 reaper 標記下線。
# 預設 75000 (75 秒，比 plugin 端預設 60s heartbeat 寬限多 15 秒)
# PLUGIN_HEARTBEAT_TIMEOUT_MS=75000

# Plugin reaper 執行週期（毫秒）。定期掃描並標記逾時的 plugin。
# 預設 30000 (30 秒)
# PLUGIN_REAPER_INTERVAL_MS=30000

# Plugin 事件派送超時（毫秒）。POST 到 plugin /events endpoint 的最長等待時間。
# 預設 5000 (5 秒)
# PLUGIN_DISPATCH_TIMEOUT_MS=5000

# Plugin slash command 派送超時（毫秒）。POST 到 plugin /commands endpoint 的最長等待時間。
# 預設 5000 (5 秒)
# PLUGIN_COMMAND_DISPATCH_TIMEOUT_MS=5000

# Plugin autocomplete 派送超時（毫秒）。Autocomplete 必須同步回應，超時回空清單。
# 預設 1500 (1.5 秒)
# PLUGIN_AUTOCOMPLETE_TIMEOUT_MS=1500

# Plugin KV value 最大位元組數（硬上限，不受 manifest quota 放寬）。
# 預設 65536 (64 KiB)
# PLUGIN_KV_VALUE_MAX_BYTES=65536

# Behavior 用戶個人資料快取 TTL（毫秒）。減少 Discord API 呼叫次數。
# 預設 300000 (5 分鐘)
# BEHAVIOR_PROFILE_CACHE_TTL_MS=300000

# Admin 用戶個人資料快取 TTL（毫秒）。Admin 介面顯示頭像 / 用戶名稱用。
# 預設 300000 (5 分鐘)
# ADMIN_PROFILE_CACHE_TTL_MS=300000

# Admin 用戶 session / 權限快取 TTL（毫秒）。角色變更後最慢在此時間內生效。
# 預設 30000 (30 秒)
# ADMIN_SESSION_CACHE_TTL_MS=30000

# RCON 連線重試次數上限。超過後放棄並通知頻道。
# 預設 3
# RCON_MAX_RETRY_ATTEMPTS=3

# RCON 指令佇列長度上限。超過上限的指令被丟棄。
# 預設 100
# RCON_MAX_QUEUE_SIZE=100

# RCON 連線閒置超時（毫秒）。超過此時間未使用的連線會被清理。
# 預設 1800000 (30 分鐘)
# RCON_CONNECTION_TIMEOUT_MS=1800000

# RCON 閒置連線清理週期（毫秒）。定期掃描並清理逾時的 RCON 連線。
# 預設 300000 (5 分鐘)
# RCON_CLEANUP_INTERVAL_MS=300000

# Bot event log dedup 視窗（毫秒）。同一 key 在此視窗內只記錄一次。
# 預設 60000 (60 秒)
# BOT_EVENTS_DEDUP_WINDOW_MS=60000

# Bot event log dedup 最大 key 數。超過後淘汰最舊的 key。
# 預設 1000
# BOT_EVENTS_DEDUP_MAX_KEYS=1000

# DM 未讀訊息計數最大抓取數量。每個 DM channel 最多數到此數目。
# 預設 500
# DM_MAX_FETCH_COUNT=500

# DM sticker proxy 最大回應位元組數。防止惡意 upstream 傳送超大 blob。
# 預設 1000000 (1 MB)
# DM_MAX_ATTACHMENT_BYTES=1000000
