# Discord Bot Token
BOT_TOKEN=your_BOT_TOKEN_here

# Node 環境
NODE_ENV=production

# 用於加密 RCON 密碼等敏感資料的金鑰
# 產生方式：openssl rand -hex 32
ENCRYPTION_KEY=

# Web 管理介面對外監聽埠（host 端），預設 902
WEB_PORT=902

# Bot 持有者的 Discord user id（僅此 id 可透過私訊 bot 取得 admin 登入連結）
# 未設定時 /api/* 不啟用驗證（僅本機 dev 暫用）
BOT_OWNER_ID=

# 前端對外網址，bot 私訊回傳的登入連結會以此為 base
# 走 HTTPS 時請填 https://${DOMAIN}:${WEB_PORT}
WEB_BASE_URL=https://bot.example.com:902

# --- HTTPS 憑證 ---
# Host 上放置憑證的絕對目錄，內含 fullchain.pem 與 privkey.pem。
# docker-compose 會以 read-only mount 到 container 的 /certs，
# 對應 SSL_CERT_PATH=/certs/fullchain.pem、SSL_KEY_PATH=/certs/privkey.pem（已寫在 compose）。
#
# 建議在 Mac host 用 acme.sh 搭配 Cloudflare DNS-01 簽發（Cloudflare 請保持灰雲）：
#
#   # 安裝（會自動建立 crontab 做續期）
#   curl https://get.acme.sh | sh -s email=you@example.com
#
#   # 設定 Cloudflare API token（Zone/DNS/Edit，限定 zone）
#   export CF_Token="your_cloudflare_api_token"
#
#   # 簽發
#   ~/.acme.sh/acme.sh --issue --dns dns_cf -d bot.example.com
#
#   # 安裝到固定路徑 + 續期後自動重啟 bot container
#   mkdir -p $HOME/karyl-chan/certs
#   ~/.acme.sh/acme.sh --install-cert -d bot.example.com \
#     --fullchain-file $HOME/karyl-chan/certs/fullchain.pem \
#     --key-file       $HOME/karyl-chan/certs/privkey.pem \
#     --reloadcmd      "docker restart karyl-chan-bot-1"
#
# 註：bot 讀取憑證只在啟動時（readFileSync），因此 acme.sh 續期後
# 需要重啟 container 才會吃到新憑證，reloadcmd 就是做這件事。
CERTS_DIR=/Users/yourname/karyl-chan/certs
