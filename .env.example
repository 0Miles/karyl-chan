# Discord Bot Token
BOT_TOKEN=your_BOT_TOKEN_here

# Node 環境
NODE_ENV=production

# 用於加密 RCON 密碼等敏感資料的金鑰
# 產生方式：openssl rand -hex 32
ENCRYPTION_KEY=

# Web 管理介面對外監聽埠（caddy sidecar），預設 902
WEB_PORT=902

# Bot 持有者的 Discord user id（僅此 id 可透過私訊 bot 取得 admin 登入連結）
# 未設定時 /api/* 不啟用驗證（僅本機 dev 暫用）
BOT_OWNER_ID=

# 前端對外網址，bot 私訊回傳的登入連結會以此為 base
# 使用 caddy + TLS 時請填 https://${DOMAIN}:${WEB_PORT}
WEB_BASE_URL=https://bot.example.com:902

# --- HTTPS via Caddy + Cloudflare DNS-01 ---
# docker-compose.yml 內的 caddy sidecar 會自動向 Let's Encrypt 申請 & 續期
# 憑證，並以 reverse proxy 轉發至 bot:3000。Cloudflare 必須為「DNS only（灰雲）」，
# 因為 Cloudflare 代理僅支援特定 port（443/2053/2083/2087/2096/8443）不含 902。

# 對外使用的 FQDN，需事先於 Cloudflare 建立 A 記錄指向家用公網 IP（灰雲）
DOMAIN=bot.example.com

# 用於 Let's Encrypt 通知的信箱
ACME_EMAIL=you@example.com

# Cloudflare API Token，scope：Zone / DNS / Edit，限定到該 zone
# 建立位置：https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# --- 直接由 bot 終結 TLS（選用，與 caddy 二擇一） ---
# 若改用自備憑證而不走 caddy，請把 docker-compose.yml 的 caddy service 移除，
# 恢復 bot 的 ports 對映，並在此設定憑證路徑（container 內路徑）。
# 其中任一檔案不存在會直接拒絕啟動，避免誤 fallback 到 HTTP。
SSL_CERT_PATH=
SSL_KEY_PATH=
# 中繼憑證鏈（選用，Let's Encrypt 的 fullchain.pem 通常已包含，可不設）
SSL_CA_PATH=
