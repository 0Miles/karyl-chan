# Discord Bot Token
BOT_TOKEN=your_BOT_TOKEN_here

# Node 環境
NODE_ENV=production

# 用於加密 RCON 密碼等敏感資料的金鑰
# 產生方式：openssl rand -hex 32
ENCRYPTION_KEY=

# Web 管理介面監聽埠，預設 3000
WEB_PORT=3000

# Bot 持有者的 Discord user id（僅此 id 可透過私訊 bot 取得 admin 登入連結）
# 未設定時 /api/* 不啟用驗證（僅本機 dev 暫用）
BOT_OWNER_ID=

# 前端對外網址，bot 私訊回傳的登入連結會以此為 base
# 未設定時 fallback 到 http://localhost:${WEB_PORT}
WEB_BASE_URL=http://localhost:5173

# HTTPS 設定（選用）。同時設定 SSL_CERT_PATH 與 SSL_KEY_PATH 才會啟用，
# 其中任一檔案不存在會直接拒絕啟動，避免誤 fallback 到 HTTP。
# 容器部署時請把憑證檔案 mount 進 container，路徑填 container 內路徑。
SSL_CERT_PATH=
SSL_KEY_PATH=
# 中繼憑證鏈（選用，Let's Encrypt 的 fullchain.pem 通常已包含，可不設）
SSL_CA_PATH=
