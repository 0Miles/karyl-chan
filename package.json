{
  "name": "karyl-chan",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "gcp-build": "npm i && npm run build",
    "build": "tsc",
    "build:changelog": "npx @discordx/changelog --root=src",
    "dev": "node --loader ts-node/esm/transpile-only src/main.ts",
    "serve": "node build/main.js",
    "start": "nodemon --exec node --loader ts-node/esm/transpile-only src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@discordx/importer": "^1.3.2",
    "discord.js": "^14.19.3",
    "discordx": "^11.12.4",
    "rcon": "^1.1.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
