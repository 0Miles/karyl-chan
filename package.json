{
  "name": "karyl-chan",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "gcp-build": "npm i && npm run build",
    "build": "tsc",
    "dev": "node --env-file=.env --loader ts-node/esm/transpile-only src/main.ts",
    "serve": "node build/main.js",
    "start": "nodemon --exec node --loader ts-node/esm/transpile-only src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "discord.js": "^14.26.3",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "rcon": "^1.1.0",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
